{
  "productName": "petmii",
  "appId": "com.petmii.app",
  "directories": {
    "output": "release"
  },
  "files": ["out/**/*"],
  "extraResources": [
    {
      "from": "build/icon.ico",
      "to": "icon.ico"
    }
  ],
  "win": {
    "target": "nsis",
    "icon": "build/icon.ico"
  },
  "mac": {
    "target": "dmg",
    "icon": "build/icon.ico"
  },
  "linux": {
    "target": "AppImage",
    "icon": "build/icon.ico"
  }
}
